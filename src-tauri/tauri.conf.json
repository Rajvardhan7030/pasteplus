{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "bundle": {
    "active": true,
    "category": "Utility",
    "copyright": "",
    "externalBin": [],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": "all",
    "longDescription": "",
    "resources": [],
    "shortDescription": ""
  },
  "productName": "PastePlus",
  "mainBinaryName": "PastePlus",
  "version": "0.1.0",
  "identifier": "com.pasteplus.app",
  "plugins": {},
  "app": {
    "security": {
      "csp": null,
      "capabilities": [
        "migrated"
      ]
    },
    "windows": [
      {
        "fullscreen": false,
        "height": 450,
        "resizable": false,
        "title": "PastePlus",
        "width": 380,
        "transparent": false,
        "decorations": true,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "visible": false,
        "label": "main",
        "useHttpsScheme": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "menuOnLeftClick": false
    }
  }
}